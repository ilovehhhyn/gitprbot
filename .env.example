# Dedalus
DEDALUS_API_KEY=your_dedalus_api_key_here

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Database (SQLite default; swap for postgresql+asyncpg://... for Postgres)
DATABASE_URL=sqlite+aiosqlite:///./gitprbot.db

# Worker identity (unique per process; used for DB lock ownership)
WORKER_ID=worker-1

# Models
STRONG_MODEL=anthropic/claude-opus-4-5
CHEAP_MODEL=anthropic/claude-haiku-4-5-20251001
EMBED_MODEL=openai/text-embedding-3-small

# Agent loop limits
MAX_STEPS=40
MAX_REPAIR_ITERATIONS=6
WALL_CLOCK_CAP_SECONDS=2700
PER_JOB_COST_CEILING_USD=2.00

# Machine defaults
MACHINE_VCPU=2
MACHINE_MEMORY_MIB=4096
MACHINE_STORAGE_GIB=20
MACHINE_AUTOSLEEP=30m

# Lock
LOCK_LEASE_TTL_SECONDS=900
LOCK_HEARTBEAT_SECONDS=120

# Memory budgets (in tokens)
REPO_MD_TOKEN_BUDGET=400
CONVENTIONS_MD_TOKEN_BUDGET=300
CONSOLIDATION_THRESHOLD=0.80

# Optional: alert webhook URL (POST JSON on alert conditions)
ALERT_WEBHOOK_URL=

# Optional: Prometheus metrics port (0 = disabled)
METRICS_PORT=9090
